# Mizan Environment Configuration Template
# Copy this file to .env and fill in your values

# ==========================================
# ArcPay / Circle Configuration
# ==========================================

# Private key for transaction signing (with 0x prefix)
PRIVATE_KEY=0x...your_private_key_here

# Circle Developer API Key
# Get yours at: https://console.circle.com/signup
CIRCLE_API_KEY=TEST_API_KEY:xxx:yyy

# Circle Entity Secret (for Developer Controlled Wallets)
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# ==========================================
# Arc Network Configuration
# ==========================================

# Arc Testnet RPC URL
ARC_TESTNET_RPC=https://rpc.testnet.arc.network

# Arc Explorer
ARC_EXPLORER_URL=https://testnet.arcscan.app

# ==========================================
# Mizan Orchestration API
# ==========================================

# Anthropic API Key (for LangGraph agents)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Mizan API Endpoint (for Kaiz demo app)
NEXT_PUBLIC_MIZAN_API=http://localhost:8000

# ==========================================
# Supabase Configuration (for Kaiz demo)
# ==========================================

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (backend only)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ==========================================
# Optional: Enterprise Circle Products
# ==========================================

# USYC API Configuration (if access granted)
# USYC_API_KEY=your-usyc-key-here

# StableFX API Configuration (if access granted)
# STABLEFX_API_KEY=your-stablefx-key-here

# ==========================================
# Development Configuration
# ==========================================

# Node environment
NODE_ENV=development

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode
DEBUG=false
